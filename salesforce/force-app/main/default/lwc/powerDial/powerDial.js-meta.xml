<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Power Dial</masterLabel>
    <description>Hands selected Lead/Opportunity record ids to the CTI power dialer via the PowerDialRelay Apex relay. See the powerDial README for Setup wiring. Admin-only during rollout.</description>
    <targets>
        <target>lightning__RecordAction</target>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <!--
          Single-record Quick Action (Lead or Opportunity record page).
          Salesforce auto-injects @api recordId. Object scoping happens in
          Setup when the Quick Action is created against a specific object.
        -->
        <targetConfig targets="lightning__RecordAction">
            <actionType>ScreenAction</actionType>
        </targetConfig>
        <!--
          The multi-record ("list view") path: embed this component as a Screen
          Flow screen component and launch the flow from a List Button that
          passes selected ids via GETRECORDIDS(). See README.md.
        -->
        <targetConfig targets="lightning__FlowScreen">
            <property name="objectApiName" type="String" label="Object API Name" role="inputOnly" />
            <property name="recordIds" type="String[]" label="Record Ids" role="inputOnly" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
