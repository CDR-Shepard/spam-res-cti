<apex:page standardController="Lead" recordSetVar="records"
    extensions="PowerDialListController" action="{!run}"
    lightningStylesheets="true" showHeader="true" title="Power Dial">
    <apex:slds />
    <div class="slds-scope slds-p-around_large">
        <h1 class="slds-text-heading_medium slds-m-bottom_small">Power Dial</h1>
        <p class="{!IF(isError, 'slds-text-color_error', 'slds-text-color_success')}">{!message}</p>
    </div>
</apex:page>
