# =============================================================================
# Caller Reputation CTI — Environment Configuration Template
# Copy to services/cti-api/.env (backend) and apps/cti-desktop/.env (renderer)
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (services/cti-api)
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# 32-byte hex key (e.g. `openssl rand -hex 32`). Encrypts at-rest OAuth tokens.
TOKEN_ENCRYPTION_KEY=replace_me_with_64_hex_chars

# Session signing for desktop ↔ backend session token (HS256). Min 32 chars.
SESSION_SECRET=replace_me_with_long_random_string

# -----------------------------------------------------------------------------
# Database (Postgres / Supabase)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cti_dev

# -----------------------------------------------------------------------------
# Salesforce Connected App
#   Setup → App Manager → New Connected App
#   - Enable OAuth Settings: yes
#   - Callback URL: ${API_PUBLIC_URL}/auth/salesforce/callback
#   - Selected scopes: api, refresh_token, offline_access
#   - Require PKCE: yes (recommended)
# -----------------------------------------------------------------------------
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:4000/auth/salesforce/callback
# login.salesforce.com (prod) or test.salesforce.com (sandbox)
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_API_VERSION=v60.0

# -----------------------------------------------------------------------------
# Telephony Provider — Twilio (default for MVP)
# -----------------------------------------------------------------------------
TELEPHONY_PROVIDER=twilio

# From Twilio Console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Used to sign Voice access tokens. Create at: Console → Account → API Keys.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# TwiML Application SID. Create at: Voice → TwiML → TwiML Apps.
# Set its Voice Request URL to ${API_PUBLIC_URL}/telephony/twilio/voice
TWILIO_TWIML_APP_SID=
# E.164 default outbound caller ID (must be verified/owned in Twilio)
TWILIO_DEFAULT_CALLER_ID=+15555550123
# Local-dev ONLY: skip Twilio webhook signature validation (e.g. replaying
# captured webhooks). Leave false/unset everywhere else — signatures are always
# enforced regardless of NODE_ENV.
TWILIO_SKIP_SIGNATURE_CHECK=false

# -----------------------------------------------------------------------------
# Telephony Provider — Telnyx (alternative; not wired in MVP)
# -----------------------------------------------------------------------------
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_DEFAULT_CALLER_ID=

# -----------------------------------------------------------------------------
# Reputation worker + alerting + CORS
# -----------------------------------------------------------------------------
# How often (ms) the worker recomputes per-DID health and auto-pauses numbers
# that cross a kill threshold. Default 600000 (10 min).
REPUTATION_WORKER_INTERVAL_MS=600000
# Optional Slack-compatible webhook for reputation/attestation/analytics-block alerts.
ALERT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# NumberVerifier (app.numberverifier.com) caller-ID reputation feed
#   In the NumberVerifier dashboard → Webhooks, set:
#     Webhook URL = ${API_PUBLIC_URL}/integrations/numberverifier/webhook
#     Verify Key  = the SAME secret you put below (sent as the x-verifykey header)
#     Version     = v2   (optionally check "Only Flagged")
#   When a monitored DID is flagged we set its health and pull it from rotation.
#   Leave NUMBERVERIFIER_VERIFY_KEY unset to disable the webhook route (503).
# -----------------------------------------------------------------------------
NUMBERVERIFIER_VERIFY_KEY=
# Future on-demand pull API (destination reassigned-number checks); not required
# for the webhook integration.
NUMBERVERIFIER_API_KEY=
NUMBERVERIFIER_API_BASE=https://app.numberverifier.com
# Production CORS allowlist (comma-separated browser origins permitted to call
# the API). The Electron desktop and Salesforce my-domains are allowed
# automatically. Leave unset in development (all origins reflected).
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Desktop (apps/cti-desktop) — VITE_* are exposed to the renderer
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000
# Packaged main process reads CTI_API_BASE_URL (or a userData/config.json
# {"apiBaseUrl": "..."}) since VITE_* only exist at renderer build time.
CTI_API_BASE_URL=http://localhost:4000
